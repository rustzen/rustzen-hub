---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getLocale, pick, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}
const { locale = getLocale(Astro.url.pathname) } = Astro.props;

const pages = [
  {
    title: 'Home',
    titleZh: '首页',
    body: 'Brand positioning and entry points for public, maintained open-source work.',
    bodyZh: '说明品牌定位，并提供公开、维护中的开源项目入口。',
  },
  {
    title: 'Docs',
    titleZh: '文档',
    body: 'Documentation entry points for repositories, engineering notes, product docs, support, and policies.',
    bodyZh: '汇总仓库说明、工程约定、产品文档、支持问题和政策入口。',
  },
  {
    title: 'Product',
    titleZh: '产品',
    body: 'Standalone app products live here. The current public product page shows Rustzen Clear.',
    bodyZh: '独立 App 产品放在这里；当前公开产品页展示 Rustzen Clear。',
  },
  {
    title: 'Policies',
    titleZh: '政策',
    body: 'Privacy, terms, refund, and contact information for the public site and product usage.',
    bodyZh: '说明公开站点和产品使用相关的隐私、条款、退款和联系方式。',
  },
];
---

<SiteLayout
  title={pick(locale, 'About — Rustzen', '关于 — Rustzen')}
  description={pick(locale, 'Rustzen maintains open-source components, templates, and tools for developer workflows.', 'Rustzen 维护面向开发者工作流的开源组件、工程模板和实用工具。')}
  active="About"
  locale={locale}
>
  <main class="page">
    <header>
      <p class="eyebrow">Rustzen</p>
      <h1>{pick(locale, 'Open-source components, templates, and tools for developer workflows', '面向开发者工作流的开源组件、工程模板和实用工具')}</h1>
      <p class="lead">{pick(locale, 'Rustzen focuses on reusable foundations, engineering templates, and practical tools rather than packaging every project as a platform. Product content is kept on the Product page.', 'Rustzen 优先维护可复用的基础组件、工程模板和实用工具，而不是把所有内容包装成平台。产品内容单独放在 Product 页面。')}</p>
    </header>

    <section class="page-map" aria-label={pick(locale, 'Page content map', '页面内容说明')}>
      {pages.map((page) => (
        <article class="glass">
          <h2>{pick(locale, page.title, page.titleZh)}</h2>
          <p>{pick(locale, page.body, page.bodyZh)}</p>
        </article>
      ))}
    </section>
  </main>
</SiteLayout>

<style>
  .page {
    max-width: 1080px;
    margin: 0 auto;
    padding: clamp(56px, 9vw, 120px) clamp(20px, 5vw, 72px);
  }
  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    line-height: 1.02;
    color: var(--ink);
  }
  .lead {
    max-width: 760px;
    margin: 20px 0 0;
    color: var(--ink-2);
    font-size: 1.12rem;
  }
  .page-map {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    margin-top: clamp(42px, 7vw, 76px);
  }
  .page-map article {
    padding: 26px;
  }
  .page-map h2 {
    margin: 0;
    color: var(--ink);
  }
  .page-map p {
    margin: 12px 0 0;
    color: var(--ink-2);
  }
  @media (max-width: 760px) {
    .page-map {
      grid-template-columns: 1fr;
    }
  }
</style>
