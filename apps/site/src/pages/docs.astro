---
import SiteLayout from '../layouts/SiteLayout.astro';
import Button from '../components/Button.astro';
import { getLocale, pick, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}
const { locale = getLocale(Astro.url.pathname) } = Astro.props;

const links = [
  { href: '/products/clear', label: 'Rustzen Clear', labelZh: 'Rustzen Clear', body: 'Product overview, safety model, and download path.', bodyZh: '产品概览、安全模型和下载入口。' },
  { href: '/help', label: 'Help & FAQ', labelZh: '帮助与 FAQ', body: 'Safety, billing, support, and compatibility answers.', bodyZh: '安全性、计费、支持和兼容性说明。' },
  { href: '/privacy', label: 'Privacy', labelZh: '隐私政策', body: 'How Rustzen product pages and apps handle data.', bodyZh: 'Rustzen 产品页面和应用如何处理数据。' },
];
---

<SiteLayout
  title={pick(locale, 'Docs — Rustzen', '文档 — Rustzen')}
  description={pick(locale, 'Documentation entry points for Rustzen products.', 'Rustzen 产品文档入口。')}
  active="Docs"
  locale={locale}
>
  <main class="page">
    <header class="page-head">
      <p class="eyebrow">{pick(locale, 'Docs', '文档')}</p>
      <h1>{pick(locale, 'Find the right Rustzen product documentation.', '找到 Rustzen 产品文档。')}</h1>
    </header>
    <section class="doc-grid">
      {links.map((link) => (
        <article class="glass doc-card">
          <h2>{pick(locale, link.label, link.labelZh)}</h2>
          <p>{pick(locale, link.body, link.bodyZh)}</p>
          <Button href={link.href} variant="secondary">{pick(locale, 'Open', '打开')}</Button>
        </article>
      ))}
    </section>
  </main>
</SiteLayout>

<style>
  .page {
    max-width: 1060px;
    margin: 0 auto;
    padding: clamp(48px, 7vw, 96px) clamp(20px, 5vw, 72px);
  }
  h1 {
    margin: 0;
    max-width: 720px;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    line-height: 1.05;
    color: var(--ink);
  }
  .doc-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin-top: 36px;
  }
  .doc-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 26px;
  }
  .doc-card h2 {
    margin: 0;
    color: var(--ink);
  }
  .doc-card p {
    flex: 1;
    margin: 0;
    color: var(--ink-2);
  }
  @media (max-width: 840px) {
    .doc-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
