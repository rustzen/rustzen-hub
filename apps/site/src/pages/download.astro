---
import SiteLayout from '../layouts/SiteLayout.astro';
import Button from '../components/Button.astro';
import { product } from '../data/product';
import { getLocale, pick, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}
const { locale = getLocale(Astro.url.pathname) } = Astro.props;
---

<SiteLayout
  title={pick(locale, 'Download — Rustzen', '下载 — Rustzen')}
  description={pick(locale, 'Download Rustzen Clear for macOS.', '下载 Rustzen Clear macOS 版。')}
  active="Download"
  locale={locale}
>
  <main class="page">
    <header class="page-head">
      <p class="eyebrow">{pick(locale, 'Download', '下载')}</p>
      <h1>{pick(locale, 'Get Rustzen Clear for macOS.', '下载 Rustzen Clear macOS 版。')}</h1>
      <p class="sub">{pick(locale, product.trust, product.trustZh)}</p>
      <Button href={product.download.href} variant="primary">{pick(locale, product.download.label, product.download.labelZh)}</Button>
    </header>
  </main>
</SiteLayout>

<style>
  .page {
    max-width: 820px;
    margin: 0 auto;
    padding: clamp(56px, 9vw, 120px) clamp(20px, 5vw, 72px);
  }
  h1 {
    margin: 0 0 16px;
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, 4rem);
    line-height: 1.02;
    color: var(--ink);
  }
  .sub {
    margin: 0 0 28px;
    color: var(--ink-2);
    font-size: 1.1rem;
  }
</style>
