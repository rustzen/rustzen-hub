---
import SiteLayout from '../layouts/SiteLayout.astro';
import Button from '../components/Button.astro';
import { product } from '../data/product';
import { getLocale, pick, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}
const { locale = getLocale(Astro.url.pathname) } = Astro.props;
---

<SiteLayout
  title={pick(locale, 'Help & FAQ — Zen Clear | Rustzen', '帮助与 FAQ — Zen Clear | Rustzen')}
  description={pick(
    locale,
    'Answers to common Zen Clear questions on safety, supported macOS versions, scan coverage, and Pro billing.',
    '关于 Zen Clear 安全性、支持的 macOS 版本、扫描范围与 Pro 计费的常见问题解答。',
  )}
  active="Help"
  locale={locale}
>
  <main class="page">
    <header class="page-head">
      <p class="eyebrow">{pick(locale, 'Help', '帮助')}</p>
      <h1>{pick(locale, product.faqTitle, product.faqTitleZh)}</h1>
    </header>

    <div class="faq-list">
      {product.faq.map((item) => (
        <details class="glass-2 faq-item">
          <summary>{pick(locale, item.q, item.qZh)}</summary>
          <p>{pick(locale, item.a, item.aZh)}</p>
        </details>
      ))}
    </div>

    <section class="contact glass">
      <div>
        <h2>{pick(locale, 'Still need help?', '还需要帮助？')}</h2>
        <p>{pick(locale, 'Email us for license, billing, or refund questions. Include your checkout email and app version.', '许可证、账单或退款问题请邮件联系我们，请附上结账邮箱与应用版本。')}</p>
      </div>
      <Button variant="primary" href="mailto:support@rustzen.dev">{pick(locale, 'Email support', '邮件支持')}</Button>
    </section>
  </main>
</SiteLayout>

<style>
  .page {
    max-width: 820px;
    margin: 0 auto;
    padding: clamp(48px, 7vw, 92px) clamp(20px, 5vw, 72px);
  }
  .page-head {
    margin-bottom: 34px;
  }
  .page-head h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .faq-list {
    display: grid;
    gap: 12px;
  }
  .faq-item {
    padding: 4px 22px;
    border-radius: var(--radius);
  }
  .faq-item summary {
    padding: 16px 0;
    cursor: pointer;
    font-weight: 600;
    color: var(--ink);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item summary::after {
    content: '+';
    color: var(--brand-600);
    font-size: 1.4rem;
    transition: transform var(--motion-fast) var(--ease-standard);
  }
  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }
  .faq-item p {
    margin: 0 0 18px;
    color: var(--ink-2);
  }
  .contact {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-top: 36px;
    padding: 28px 30px;
    border-radius: var(--radius-lg);
  }
  .contact h2 {
    margin: 0;
    font-size: 1.25rem;
    color: var(--ink);
  }
  .contact p {
    margin: 6px 0 0;
    color: var(--ink-2);
    max-width: 460px;
  }
  @media (max-width: 640px) {
    .contact {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
