---
import SiteLayout from '../layouts/SiteLayout.astro';
import { githubUrl } from '../data/product';
import { getLocale, pick, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}
const { locale = getLocale(Astro.url.pathname) } = Astro.props;

const values = [
  {
    title: 'Local-first',
    titleZh: '本地优先',
    body: 'Prefer local data and local execution when the workflow does not need a remote service.',
    bodyZh: '在工作流不需要远端服务时，优先把数据和执行留在本机。',
  },
  {
    title: 'Small scope',
    titleZh: '范围明确',
    body: 'Keep each project focused on a clear engineering job instead of presenting everything as a platform.',
    bodyZh: '让每个项目服务清楚的工程任务，而不是把所有内容包装成平台。',
  },
  {
    title: 'Readable behavior',
    titleZh: '行为可理解',
    body: 'Keep commands, documentation, and product boundaries easy to inspect and explain.',
    bodyZh: '让命令、文档和产品边界尽量容易检查、理解和说明。',
  },
  {
    title: 'Cautious AI',
    titleZh: '谨慎使用 AI',
    body: 'Use AI where it helps reading or operating workflows, with visible inputs and recoverable actions.',
    bodyZh: '只在能帮助理解或操作工作流的地方使用 AI，并保留清晰输入和可回退动作。',
  },
];

const openProjects = [
  {
    name: 'rustzen-core',
    href: 'https://github.com/rustzen/rustzen-core',
    status: 'Shared Rust components',
    statusZh: '共享 Rust 基础组件',
    body: 'Shared Rust primitives and crates for common models, configuration, error handling, and engineering conventions.',
    bodyZh: 'Rustzen 项目之间复用的 Rust 基础代码和 crate，用于沉淀通用模型、配置、错误处理和工程约定。',
  },
  {
    name: 'rustzen-admin',
    href: 'https://github.com/rustzen/rustzen-admin',
    status: 'Web/Rust admin template',
    statusZh: 'Web/Rust 后台工程模板',
    body: 'A Web/Rust admin template with server, web app, shared crates, and deployment scripts.',
    bodyZh: '一个 Web/Rust 后台工程模板，包含服务端、前端、共享 crate 和部署脚本，可作为后台系统、控制台和内部工具的工程起点。',
  },
];
---

<SiteLayout
  title={pick(locale, 'Rustzen — Open-source components, templates, and tools', 'Rustzen — 开源组件、工程模板和工具')}
  description={pick(locale, 'Rustzen maintains open-source components, templates, and tools for developer workflows.', 'Rustzen 维护面向开发者工作流的开源组件、工程模板和实用工具。')}
  active="Home"
  locale={locale}
>
  <main class="home">
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Rustzen</p>
        <h1>{pick(locale, 'Open-source components, templates, and tools for developer workflows', 'Rustzen 的开源组件、工程模板和工具')}</h1>
        <p class="lead">
          {pick(
            locale,
            'Rustzen maintains open-source projects for developer workflows: shared Rust components, Web/Rust admin templates, and practical tools for release workflows. Standalone app products are kept on separate product pages.',
            'Rustzen 维护面向开发者工作流的公开项目：共享 Rust 基础组件、Web/Rust 后台工程模板，以及用于发布流程的实用工具。独立 App 产品单独放在产品页。'
          )}
        </p>
      </div>
    </section>

    <section class="values" aria-labelledby="values-title">
      <div class="section-head">
        <p class="eyebrow">{pick(locale, 'How we work', '工作方式')}</p>
        <h2 id="values-title">{pick(locale, 'Clear scope, local-first where practical, and inspectable behavior', '边界清晰、适合时本地优先、行为可检查')}</h2>
      </div>
      <div class="value-grid">
        {values.map((item) => (
          <article class="glass value-card">
            <h3>{pick(locale, item.title, item.titleZh)}</h3>
            <p>{pick(locale, item.body, item.bodyZh)}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="open-work" aria-labelledby="open-work-title">
      <div class="section-head split">
        <div>
          <p class="eyebrow">{pick(locale, 'Open work', '开源工作')}</p>
          <h2 id="open-work-title">{pick(locale, 'Public repositories currently maintained', '当前公开并维护中的项目')}</h2>
        </div>
        <a class="text-link" href={githubUrl} target="_blank" rel="noreferrer">GitHub</a>
      </div>
      <div class="open-grid">
        {openProjects.map((item) => (
          <a class="glass open-card" href={item.href} target="_blank" rel="noreferrer">
            <p class="status">{pick(locale, item.status, item.statusZh)}</p>
            <h3>{item.name}</h3>
            <p>{pick(locale, item.body, item.bodyZh)}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="why" aria-labelledby="why-title">
      <div class="section-head">
        <p class="eyebrow">{pick(locale, 'What stays on the home page', '首页展示原则')}</p>
        <h2 id="why-title">{pick(locale, 'Keep the home page about public, verifiable work', '首页聚焦公开、可检查的基础能力')}</h2>
      </div>
      <div class="why-list">
        <article class="glass-2">
          <h3>{pick(locale, 'Public projects first', '公开项目优先')}</h3>
          <p>{pick(locale, 'The home page points to repositories that can be opened, read, and checked directly.', '首页优先指向可以直接打开、阅读和检查的仓库。')}</p>
        </article>
        <article class="glass-2">
          <h3>{pick(locale, 'Products stay separate', '产品单独展示')}</h3>
          <p>{pick(locale, 'Commercial product details belong on the product page, not mixed into the home page.', '商业产品详情放在产品页，不混在首页的开源项目介绍里。')}</p>
        </article>
        <article class="glass-2">
          <h3>{pick(locale, 'No inflated claims', '不过度包装')}</h3>
          <p>{pick(locale, 'Descriptions should say what exists today and avoid promising more than the project shows.', '文案只说明当前已经存在的内容，避免超过项目现状的承诺。')}</p>
        </article>
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .home {
    overflow: hidden;
  }

  .hero {
    max-width: 1180px;
    margin: 0 auto;
    padding: clamp(52px, 8vw, 108px) clamp(20px, 5vw, 72px) clamp(56px, 9vw, 112px);
  }

  .hero-copy h1,
  .section-head h2 {
    margin: 0;
    font-family: var(--font-display);
    color: var(--ink);
    letter-spacing: 0;
  }

  .hero-copy h1 {
    max-width: 760px;
    font-size: clamp(2.7rem, 6vw, 5rem);
    line-height: 1.02;
  }

  .lead {
    max-width: 650px;
    margin: 22px 0 0;
    color: var(--ink-2);
    font-size: clamp(1.05rem, 1.7vw, 1.24rem);
  }

  .values,
  .open-work,
  .why {
    padding: clamp(48px, 7vw, 92px) clamp(20px, 5vw, 72px);
  }

  .section-head {
    max-width: 760px;
    margin-bottom: 32px;
  }

  .section-head.split {
    max-width: none;
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: end;
  }

  .section-head h2 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.06;
  }

  .value-grid,
  .open-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  .value-card,
  .open-card,
  .why-list article {
    padding: 26px;
  }

  .value-card h3,
  .open-card h3,
  .why-list h3 {
    margin: 0;
    color: var(--ink);
    font-size: 1.15rem;
  }

  .value-card p,
  .open-card p,
  .why-list p {
    margin: 10px 0 0;
    color: var(--ink-2);
    font-size: 0.98rem;
  }

  .status {
    margin: 0 0 14px !important;
    color: var(--brand-600) !important;
    font-family: var(--font-mono);
    font-size: 0.78rem !important;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .open-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .open-card {
    display: block;
    min-height: 210px;
  }

  .text-link {
    color: var(--brand-600);
    font-weight: 700;
  }

  .why-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .open-card:hover,
  .value-card:hover {
    transform: translateY(-2px);
  }

  @media (max-width: 980px) {
    .value-grid,
    .open-grid,
    .why-list {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 680px) {
    .value-grid,
    .open-grid,
    .why-list {
      grid-template-columns: 1fr;
    }
    .section-head.split {
      display: block;
    }
    .text-link {
      display: inline-block;
      margin-top: 14px;
    }
  }
</style>
