---
import SiteLayout from '../layouts/SiteLayout.astro';
import Button from '../components/Button.astro';
import { docsUrl, githubUrl, publicProducts } from '../data/product';
import { getLocale, pick, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}
const { locale = getLocale(Astro.url.pathname) } = Astro.props;

function localizeSiteHref(href: string) {
  return locale === 'zh' && href.startsWith('/') ? `/zh${href}` : href;
}

const values = [
  {
    title: 'Local-first',
    titleZh: '本地优先',
    body: 'Keep work data close to the machine unless a cloud service is genuinely needed.',
    bodyZh: '默认让工作数据留在本机，只有确实需要时才使用云端能力。',
  },
  {
    title: 'Fast by default',
    titleZh: '默认高性能',
    body: 'Use native apps, focused CLIs, and small workflows that feel immediate.',
    bodyZh: '用原生应用、聚焦 CLI 和轻量工作流，让常用操作保持即时反馈。',
  },
  {
    title: 'Plain and reliable',
    titleZh: '简洁可靠',
    body: 'Prefer clear explanations, reversible actions, and predictable product behavior.',
    bodyZh: '重视清晰解释、可恢复操作和可预期的产品行为。',
  },
  {
    title: 'AI-assisted',
    titleZh: 'AI 辅助',
    body: 'Use AI to help understand workflows, not to hide risky automation behind magic.',
    bodyZh: '用 AI 帮助理解工作流，而不是把高风险自动化藏在黑盒里。',
  },
];

const paths = [
  {
    label: 'GitHub',
    labelZh: 'GitHub',
    href: githubUrl,
    body: 'Follow open-source Rustzen work, active repositories, releases, and engineering notes.',
    bodyZh: '查看 Rustzen 已开源和正在推进的仓库、发布与工程记录。',
  },
  {
    label: 'Docs',
    labelZh: '文档',
    href: docsUrl,
    body: 'Read entry points for open projects, current product notes, support, and policies.',
    bodyZh: '查看开源项目入口、当前产品说明、支持信息和政策入口。',
  },
  {
    label: 'Product',
    labelZh: '产品',
    href: '/products',
    body: 'Private Rustzen products are listed separately. The public product page currently shows Clear only.',
    bodyZh: '私有 Rustzen 产品单独展示；当前公开产品页仅显示 Clear。',
  },
];
---

<SiteLayout
  title={pick(locale, 'Rustzen — Local-first tools for developers and makers', 'Rustzen — 面向开发者和创造者的本地优先工具')}
  description={pick(locale, 'Rustzen builds fast, local-first tools for modern developer workflows.', 'Rustzen 构建快速、本地优先的现代开发者工作流工具。')}
  active="Home"
  locale={locale}
>
  <main class="home">
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Rustzen</p>
        <h1>{pick(locale, 'Local-first tools for developers and makers.', '面向开发者和创造者的本地优先工具。')}</h1>
        <p class="lead">
          {pick(
            locale,
            'Rustzen builds fast, practical tools for local development, desktop productivity, release workflows, and the services that support them.',
            'Rustzen 构建快速、实用的工具，服务于本地开发、桌面效率、发布工作流，以及支撑这些产品的云端能力。'
          )}
        </p>
        <div class="actions">
          <Button href={githubUrl} variant="primary" target="_blank" rel="noreferrer">
            GitHub
          </Button>
          <Button href={docsUrl} variant="secondary">
            {pick(locale, 'Docs', '文档')}
          </Button>
          <Button href={pick(locale, '/products', '/zh/products')} variant="ghost">
            {pick(locale, 'Product', '产品')}
          </Button>
        </div>
      </div>
    </section>

    <section class="values" aria-labelledby="values-title">
      <div class="section-head">
        <p class="eyebrow">{pick(locale, 'What Rustzen is', 'Rustzen 是什么')}</p>
        <h2 id="values-title">{pick(locale, 'A focused product line for modern local work.', '一组聚焦现代本地工作的产品线。')}</h2>
      </div>
      <div class="value-grid">
        {values.map((item) => (
          <article class="glass value-card">
            <h3>{pick(locale, item.title, item.titleZh)}</h3>
            <p>{pick(locale, item.body, item.bodyZh)}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="products" aria-labelledby="products-title">
      <div class="section-head split">
        <div>
          <p class="eyebrow">{pick(locale, 'Product', '产品')}</p>
          <h2 id="products-title">{pick(locale, 'Private products, shown deliberately.', '私有产品，谨慎公开展示。')}</h2>
        </div>
        <a class="text-link" href={pick(locale, '/products', '/zh/products')}>{pick(locale, 'Product page', '产品页')}</a>
      </div>
      <div class="product-grid">
        {publicProducts.map((item) => (
          <article class="glass product-card" data-accent={item.accent}>
            <p class="status">{pick(locale, item.status, item.statusZh)}</p>
            <h3>{pick(locale, item.name, item.nameZh)}</h3>
            <p>{pick(locale, item.summary, item.summaryZh)}</p>
            <div class="product-actions">
              <a href={localizeSiteHref(item.href)} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noreferrer' : undefined}>
                {pick(locale, 'View product', '查看产品')}
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="why" aria-labelledby="why-title">
      <div class="section-head">
        <p class="eyebrow">{pick(locale, 'Why use Rustzen', '为什么使用 Rustzen')}</p>
        <h2 id="why-title">{pick(locale, 'Designed for people who live in real workflows.', '为真实工作流中的用户设计。')}</h2>
      </div>
      <div class="why-list">
        <article class="glass-2">
          <h3>{pick(locale, 'Reduce invisible local clutter', '减少不可见的本地负担')}</h3>
          <p>{pick(locale, 'Make generated files, caches, releases, and product operations easier to understand and control.', '让生成文件、缓存、发布和产品运营变得更容易理解和控制。')}</p>
        </article>
        <article class="glass-2">
          <h3>{pick(locale, 'Avoid overbuilt tools', '避免过度复杂')}</h3>
          <p>{pick(locale, 'Each product starts with a sharp workflow instead of a generic platform story.', '每个产品都从明确工作流出发，而不是先讲一个泛平台故事。')}</p>
        </article>
        <article class="glass-2">
          <h3>{pick(locale, 'Keep the path open', '保持入口清晰')}</h3>
          <p>{pick(locale, 'Use the product, read the docs, or inspect the source from one brand home.', '从同一个品牌入口使用产品、阅读文档或查看源码。')}</p>
        </article>
      </div>
    </section>

    <section class="entry" aria-labelledby="entry-title">
      <div class="section-head">
        <p class="eyebrow">{pick(locale, 'Next steps', '后续入口')}</p>
        <h2 id="entry-title">{pick(locale, 'Go where the work is.', '直接进入需要的地方。')}</h2>
      </div>
      <div class="entry-grid">
        {paths.map((item) => (
          <a class="glass entry-card" href={localizeSiteHref(item.href)} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noreferrer' : undefined}>
            <span>{pick(locale, item.label, item.labelZh)}</span>
            <p>{pick(locale, item.body, item.bodyZh)}</p>
          </a>
        ))}
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .home {
    overflow: hidden;
  }

  .hero {
    max-width: 1180px;
    margin: 0 auto;
    padding: clamp(52px, 8vw, 108px) clamp(20px, 5vw, 72px) clamp(56px, 9vw, 112px);
  }

  .hero-copy h1,
  .section-head h2 {
    margin: 0;
    font-family: var(--font-display);
    color: var(--ink);
    letter-spacing: 0;
  }

  .hero-copy h1 {
    max-width: 760px;
    font-size: clamp(2.7rem, 6vw, 5rem);
    line-height: 1.02;
  }

  .lead {
    max-width: 650px;
    margin: 22px 0 0;
    color: var(--ink-2);
    font-size: clamp(1.05rem, 1.7vw, 1.24rem);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .values,
  .products,
  .why,
  .entry {
    padding: clamp(48px, 7vw, 92px) clamp(20px, 5vw, 72px);
  }

  .section-head {
    max-width: 760px;
    margin-bottom: 32px;
  }

  .section-head.split {
    max-width: none;
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: end;
  }

  .section-head h2 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.06;
  }

  .value-grid,
  .product-grid,
  .entry-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  .value-card,
  .product-card,
  .entry-card,
  .why-list article {
    padding: 26px;
  }

  .value-card h3,
  .product-card h3,
  .entry-card span,
  .why-list h3 {
    margin: 0;
    color: var(--ink);
    font-size: 1.15rem;
  }

  .value-card p,
  .product-card p,
  .entry-card p,
  .why-list p {
    margin: 10px 0 0;
    color: var(--ink-2);
    font-size: 0.98rem;
  }

  .status {
    margin: 0 0 14px !important;
    color: var(--brand-600) !important;
    font-family: var(--font-mono);
    font-size: 0.78rem !important;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .product-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 22px;
  }

  .product-actions a,
  .text-link {
    color: var(--brand-600);
    font-weight: 700;
  }

  .why-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .entry-card {
    display: block;
  }

  .entry-card:hover,
  .product-card:hover,
  .value-card:hover {
    transform: translateY(-2px);
  }

  @media (max-width: 980px) {
    .value-grid,
    .product-grid,
    .why-list,
    .entry-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 680px) {
    .value-grid,
    .product-grid,
    .why-list,
    .entry-grid {
      grid-template-columns: 1fr;
    }
    .section-head.split {
      display: block;
    }
    .text-link {
      display: inline-block;
      margin-top: 14px;
    }
  }
</style>
