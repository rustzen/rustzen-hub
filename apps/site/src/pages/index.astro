---
import SiteLayout from '../layouts/SiteLayout.astro';
import { githubUrl, publicProducts } from '../data/product';
import { getLocale, pick, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}
const { locale = getLocale(Astro.url.pathname) } = Astro.props;

function localizeSiteHref(href: string) {
  return locale === 'zh' && href.startsWith('/') ? `/zh${href}` : href;
}

const values = [
  {
    title: 'Local-first',
    titleZh: '本地优先',
    body: 'Keep work data close to the machine unless a cloud service is genuinely needed.',
    bodyZh: '默认让工作数据留在本机，只有确实需要时才使用云端能力。',
  },
  {
    title: 'Fast by default',
    titleZh: '默认高性能',
    body: 'Use native apps, focused CLIs, and small workflows that feel immediate.',
    bodyZh: '用原生应用、聚焦 CLI 和轻量工作流，让常用操作保持即时反馈。',
  },
  {
    title: 'Plain and reliable',
    titleZh: '简洁可靠',
    body: 'Prefer clear explanations, reversible actions, and predictable product behavior.',
    bodyZh: '重视清晰解释、可恢复操作和可预期的产品行为。',
  },
  {
    title: 'AI-assisted',
    titleZh: 'AI 辅助',
    body: 'Use AI to help understand workflows, not to hide risky automation behind magic.',
    bodyZh: '用 AI 帮助理解工作流，而不是把高风险自动化藏在黑盒里。',
  },
];

const openProjects = [
  {
    name: 'rustzen-core',
    href: 'https://github.com/rustzen/rustzen-core',
    status: 'Shared Rust',
    statusZh: '共享 Rust 基础',
    body: 'Product-neutral Rust primitives and reusable crates shared across Rustzen products.',
    bodyZh: '产品无关的 Rust 基础能力和可复用 crate，供 Rustzen 产品共享。',
  },
  {
    name: 'rustzen-admin',
    href: 'https://github.com/rustzen/rustzen-admin',
    status: 'A-class reference',
    statusZh: 'A 类参考实现',
    body: 'Web/Rust admin workspace with server, web app, shared crates, deployment flow, and root justfile.',
    bodyZh: 'Web/Rust 管理后台工作区，包含服务端、前端、共享 crate、部署流程和根 justfile。',
  },
  {
    name: 'rustzen-zipper',
    href: 'https://github.com/rustzen/rustzen-zipper',
    status: 'CLI package',
    statusZh: 'CLI 包',
    body: 'Rust CLI and npm package for predictable zip archive creation in scripts and release workflows.',
    bodyZh: 'Rust CLI 和 npm 包，用于脚本和发布流程中可预期地创建 zip 归档。',
  },
  {
    name: 'rustzen-analytics',
    href: 'https://github.com/rustzen/rustzen-analytics',
    status: 'Analytics service',
    statusZh: '分析服务',
    body: 'Web/Rust analytics system for event ingestion, reporting, scheduling, and dashboard workflows.',
    bodyZh: 'Web/Rust 分析系统，覆盖事件采集、报表、调度和看板工作流。',
  },
  {
    name: 'rustzen-inspect',
    href: 'https://github.com/rustzen/rustzen-inspect',
    status: 'Monitoring',
    statusZh: '监控系统',
    body: 'Multi-process monitoring platform with server, agent, shared core, and web frontend.',
    bodyZh: '多进程监控平台，包含 server、agent、共享核心和 Web 前端。',
  },
  {
    name: 'rustzen-report',
    href: 'https://github.com/rustzen/rustzen-report',
    status: 'Reports',
    statusZh: '报表系统',
    body: 'Report service workspace with backend, web UI, deployment assets, and scheduled report flows.',
    bodyZh: '报表服务工作区，包含后端、Web UI、部署资源和定时报表流程。',
  },
];
---

<SiteLayout
  title={pick(locale, 'Rustzen — Local-first tools for developers and makers', 'Rustzen — 面向开发者和创造者的本地优先工具')}
  description={pick(locale, 'Rustzen builds fast, local-first tools for modern developer workflows.', 'Rustzen 构建快速、本地优先的现代开发者工作流工具。')}
  active="Home"
  locale={locale}
>
  <main class="home">
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">Rustzen</p>
        <h1>{pick(locale, 'Local-first tools for developers and makers.', '面向开发者和创造者的本地优先工具。')}</h1>
        <p class="lead">
          {pick(
            locale,
            'Rustzen builds fast, practical tools for local development, desktop productivity, release workflows, and the services that support them.',
            'Rustzen 构建快速、实用的工具，服务于本地开发、桌面效率、发布工作流，以及支撑这些产品的云端能力。'
          )}
        </p>
      </div>
    </section>

    <section class="values" aria-labelledby="values-title">
      <div class="section-head">
        <p class="eyebrow">{pick(locale, 'What Rustzen is', 'Rustzen 是什么')}</p>
        <h2 id="values-title">{pick(locale, 'A focused product line for modern local work.', '一组聚焦现代本地工作的产品线。')}</h2>
      </div>
      <div class="value-grid">
        {values.map((item) => (
          <article class="glass value-card">
            <h3>{pick(locale, item.title, item.titleZh)}</h3>
            <p>{pick(locale, item.body, item.bodyZh)}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="open-work" aria-labelledby="open-work-title">
      <div class="section-head split">
        <div>
          <p class="eyebrow">{pick(locale, 'Open work', '开源工作')}</p>
          <h2 id="open-work-title">{pick(locale, 'Active Rustzen repositories, named directly.', '正在推进的 Rustzen 仓库，直接说明。')}</h2>
        </div>
        <a class="text-link" href={githubUrl} target="_blank" rel="noreferrer">GitHub</a>
      </div>
      <div class="open-grid">
        {openProjects.map((item) => (
          <a class="glass open-card" href={item.href} target="_blank" rel="noreferrer">
            <p class="status">{pick(locale, item.status, item.statusZh)}</p>
            <h3>{item.name}</h3>
            <p>{pick(locale, item.body, item.bodyZh)}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="why" aria-labelledby="why-title">
      <div class="section-head">
        <p class="eyebrow">{pick(locale, 'Why use Rustzen', '为什么使用 Rustzen')}</p>
        <h2 id="why-title">{pick(locale, 'Designed for people who live in real workflows.', '为真实工作流中的用户设计。')}</h2>
      </div>
      <div class="why-list">
        <article class="glass-2">
          <h3>{pick(locale, 'Reduce invisible local clutter', '减少不可见的本地负担')}</h3>
          <p>{pick(locale, 'Make generated files, caches, releases, and product operations easier to understand and control.', '让生成文件、缓存、发布和产品运营变得更容易理解和控制。')}</p>
        </article>
        <article class="glass-2">
          <h3>{pick(locale, 'Avoid overbuilt tools', '避免过度复杂')}</h3>
          <p>{pick(locale, 'Each product starts with a sharp workflow instead of a generic platform story.', '每个产品都从明确工作流出发，而不是先讲一个泛平台故事。')}</p>
        </article>
        <article class="glass-2">
          <h3>{pick(locale, 'Keep the path open', '保持入口清晰')}</h3>
          <p>{pick(locale, 'Use the product, read the docs, or inspect the source from one brand home.', '从同一个品牌入口使用产品、阅读文档或查看源码。')}</p>
        </article>
      </div>
    </section>

    <section class="products" aria-labelledby="products-title">
      <div class="section-head split">
        <div>
          <p class="eyebrow">{pick(locale, 'Product', '产品')}</p>
          <h2 id="products-title">{pick(locale, 'Private products, shown deliberately.', '私有产品，谨慎公开展示。')}</h2>
        </div>
        <a class="text-link" href={pick(locale, '/products', '/zh/products')}>{pick(locale, 'Clear product page', 'Clear 产品页')}</a>
      </div>
      <div class="product-grid">
        {publicProducts.map((item) => (
          <article class="glass product-card" data-accent={item.accent}>
            <p class="status">{pick(locale, item.status, item.statusZh)}</p>
            <h3>{pick(locale, item.name, item.nameZh)}</h3>
            <p>{pick(locale, item.summary, item.summaryZh)}</p>
            <div class="product-actions">
              <a href={localizeSiteHref(item.href)} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noreferrer' : undefined}>
                {pick(locale, 'View product', '查看产品')}
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .home {
    overflow: hidden;
  }

  .hero {
    max-width: 1180px;
    margin: 0 auto;
    padding: clamp(52px, 8vw, 108px) clamp(20px, 5vw, 72px) clamp(56px, 9vw, 112px);
  }

  .hero-copy h1,
  .section-head h2 {
    margin: 0;
    font-family: var(--font-display);
    color: var(--ink);
    letter-spacing: 0;
  }

  .hero-copy h1 {
    max-width: 760px;
    font-size: clamp(2.7rem, 6vw, 5rem);
    line-height: 1.02;
  }

  .lead {
    max-width: 650px;
    margin: 22px 0 0;
    color: var(--ink-2);
    font-size: clamp(1.05rem, 1.7vw, 1.24rem);
  }

  .values,
  .open-work,
  .products,
  .why {
    padding: clamp(48px, 7vw, 92px) clamp(20px, 5vw, 72px);
  }

  .section-head {
    max-width: 760px;
    margin-bottom: 32px;
  }

  .section-head.split {
    max-width: none;
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: end;
  }

  .section-head h2 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.06;
  }

  .value-grid,
  .open-grid,
  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  .value-card,
  .open-card,
  .product-card,
  .why-list article {
    padding: 26px;
  }

  .value-card h3,
  .open-card h3,
  .product-card h3,
  .why-list h3 {
    margin: 0;
    color: var(--ink);
    font-size: 1.15rem;
  }

  .value-card p,
  .open-card p,
  .product-card p,
  .why-list p {
    margin: 10px 0 0;
    color: var(--ink-2);
    font-size: 0.98rem;
  }

  .status {
    margin: 0 0 14px !important;
    color: var(--brand-600) !important;
    font-family: var(--font-mono);
    font-size: 0.78rem !important;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .open-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .open-card {
    display: block;
    min-height: 210px;
  }

  .product-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 22px;
  }

  .product-actions a,
  .text-link {
    color: var(--brand-600);
    font-weight: 700;
  }

  .why-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .open-card:hover,
  .product-card:hover,
  .value-card:hover {
    transform: translateY(-2px);
  }

  @media (max-width: 980px) {
    .value-grid,
    .open-grid,
    .product-grid,
    .why-list {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 680px) {
    .value-grid,
    .open-grid,
    .product-grid,
    .why-list {
      grid-template-columns: 1fr;
    }
    .section-head.split {
      display: block;
    }
    .text-link {
      display: inline-block;
      margin-top: 14px;
    }
  }
</style>
