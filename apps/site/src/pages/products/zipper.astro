---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Button from '../../components/Button.astro';
import { products } from '../../data/product';
import { getLocale, pick, type Locale } from '../../i18n';

interface Props {
  locale?: Locale;
}
const { locale = getLocale(Astro.url.pathname) } = Astro.props;
const item = products.find((product) => product.slug === 'zipper')!;

const features = [
  {
    title: 'Predictable archives',
    titleZh: '可预期的归档',
    body: 'Keep compression and extraction behavior explicit for scripts, release tasks, and repeatable local packaging.',
    bodyZh: '让脚本、发布任务和可重复本地打包中的压缩 / 解压行为保持明确。',
  },
  {
    title: 'CLI-first workflow',
    titleZh: 'CLI 优先工作流',
    body: 'Designed for terminal usage, automation jobs, and simple integration with existing build or release commands.',
    bodyZh: '面向终端使用、自动化任务，以及与现有构建或发布命令的简单集成。',
  },
  {
    title: 'Rust performance',
    titleZh: 'Rust 性能',
    body: 'A small native utility direction aligned with Rustzen: fast startup, clear output, and dependable local execution.',
    bodyZh: '延续 Rustzen 的原生小工具方向：快速启动、清晰输出、可靠本地执行。',
  },
];

const workflows = [
  {
    title: 'Release packages',
    titleZh: '发布包',
    body: 'Create consistent archives for builds, binaries, assets, and handoff bundles.',
    bodyZh: '为构建产物、二进制、资源和交付包创建一致的归档文件。',
  },
  {
    title: 'Automation scripts',
    titleZh: '自动化脚本',
    body: 'Use a focused CLI when packaging needs to be repeatable across local and CI workflows.',
    bodyZh: '当本地和 CI 工作流都需要可重复打包时，使用一个专注的 CLI。',
  },
];
---

<SiteLayout
  title={pick(locale, 'Rustzen Zipper — compression CLI for release workflows', 'Rustzen Zipper — 面向发布流程的压缩 CLI')}
  description={pick(locale, item.summary, item.summaryZh)}
  active="Products"
  locale={locale}
>
  <main class="product-detail">
    <section class="hero">
      <p class="eyebrow">{pick(locale, item.status, item.statusZh)}</p>
      <h1>{item.name}</h1>
      <p class="lead">{pick(locale, item.summary, item.summaryZh)}</p>
      <p class="fit">{pick(locale, item.fit, item.fitZh)}</p>
      <div class="actions">
        <Button href={item.githubHref} variant="primary" target="_blank" rel="noreferrer">GitHub</Button>
        <Button href={item.docsHref} variant="secondary">{pick(locale, 'Docs', '文档')}</Button>
      </div>
    </section>

    <section class="split" aria-label={pick(locale, 'Core workflow', '核心工作流')}>
      <div>
        <p class="eyebrow">{pick(locale, 'What it solves', '解决什么问题')}</p>
        <h2>{pick(locale, 'Packaging should be scriptable, boring, and repeatable.', '打包应该可脚本化、稳定、可重复。')}</h2>
      </div>
      <p>
        {pick(
          locale,
          'Rustzen Zipper is the CLI side of the Rustzen tool line: a focused utility for compression and extraction tasks that show up in local automation and release pipelines.',
          'Rustzen Zipper 是 Rustzen 工具线里的 CLI 侧产品：一个专注于压缩和解压任务的小工具，服务于本地自动化和发布流水线。',
        )}
      </p>
    </section>

    <section class="grid" aria-label={pick(locale, 'Features', '功能')}>
      {features.map((feature) => (
        <article>
          <h2>{pick(locale, feature.title, feature.titleZh)}</h2>
          <p>{pick(locale, feature.body, feature.bodyZh)}</p>
        </article>
      ))}
    </section>

    <section class="grid compact" aria-label={pick(locale, 'Use cases', '使用场景')}>
      {workflows.map((workflow) => (
        <article>
          <h2>{pick(locale, workflow.title, workflow.titleZh)}</h2>
          <p>{pick(locale, workflow.body, workflow.bodyZh)}</p>
        </article>
      ))}
    </section>
  </main>
</SiteLayout>

<style>
  .product-detail {
    max-width: 1120px;
    margin: 0 auto;
    padding: clamp(48px, 7vw, 96px) clamp(20px, 5vw, 72px);
  }
  .hero {
    max-width: 820px;
  }
  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5rem);
    line-height: 0.96;
    color: var(--ink);
  }
  .lead {
    max-width: 760px;
    margin: 20px 0 0;
    color: var(--ink-2);
    font-size: 1.18rem;
    line-height: 1.7;
  }
  .fit {
    max-width: 720px;
    margin: 14px 0 0;
    color: var(--muted);
    line-height: 1.7;
  }
  .actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
  }
  .split {
    display: grid;
    grid-template-columns: minmax(260px, 0.8fr) minmax(0, 1fr);
    gap: 28px;
    align-items: start;
    margin-top: clamp(52px, 8vw, 92px);
    padding-top: 34px;
    border-top: 1px solid rgba(148, 163, 184, 0.2);
  }
  .split h2,
  article h2 {
    margin: 0;
    color: var(--ink);
  }
  .split p {
    margin: 0;
    color: var(--ink-2);
    line-height: 1.75;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin-top: 30px;
  }
  .grid.compact {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  article {
    min-height: 190px;
    padding: 24px;
    border: 1px solid var(--glass-1-border);
    border-radius: var(--radius-md);
    background: var(--glass-1-bg);
  }
  article p {
    margin: 12px 0 0;
    color: var(--ink-2);
    line-height: 1.7;
  }
  @media (max-width: 820px) {
    .split,
    .grid,
    .grid.compact {
      grid-template-columns: 1fr;
    }
  }
</style>
