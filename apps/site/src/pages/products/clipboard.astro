---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Button from '../../components/Button.astro';
import { products } from '../../data/product';
import { getLocale, pick, type Locale } from '../../i18n';

interface Props {
  locale?: Locale;
}
const { locale = getLocale(Astro.url.pathname) } = Astro.props;
const item = products.find((product) => product.slug === 'clipboard')!;

const features = [
  {
    title: 'Local clipboard history',
    titleZh: '本地剪切板历史',
    body: 'Keep useful text and snippets searchable on your Mac without sending clipboard content to a remote service.',
    bodyZh: '在 Mac 本地保留可搜索的文本和片段，不把剪切板内容发送到远端服务。',
  },
  {
    title: 'Reusable snippets',
    titleZh: '可复用片段',
    body: 'Organize repeated commands, replies, prompts, and coding fragments for fast reuse across daily work.',
    bodyZh: '整理高频命令、回复、提示词和代码片段，让日常工作中的复用更快。',
  },
  {
    title: 'Workflow friendly',
    titleZh: '面向工作流',
    body: 'Designed for keyboard-first capture, search, and paste flows instead of a heavy knowledge base.',
    bodyZh: '面向键盘优先的捕获、搜索和粘贴流程，而不是沉重的知识库。',
  },
];

const audiences = [
  {
    title: 'Developers',
    titleZh: '开发者',
    body: 'Commands, stack traces, code snippets, review phrases, and recurring terminal workflows.',
    bodyZh: '命令、错误栈、代码片段、Review 用语和高频终端工作流。',
  },
  {
    title: 'Makers',
    titleZh: '创作者',
    body: 'Reusable product copy, launch notes, prompts, and operational text that should stay local.',
    bodyZh: '可复用的产品文案、发布说明、提示词和应该留在本地的运营文本。',
  },
];
---

<SiteLayout
  title={pick(locale, 'Rustzen Clipboard — local-first clipboard workflows', 'Rustzen Clipboard — 本地优先剪切板工作流')}
  description={pick(locale, item.summary, item.summaryZh)}
  active="Products"
  locale={locale}
>
  <main class="product-detail">
    <section class="hero">
      <p class="eyebrow">{pick(locale, item.status, item.statusZh)}</p>
      <h1>{item.name}</h1>
      <p class="lead">{pick(locale, item.summary, item.summaryZh)}</p>
      <p class="fit">{pick(locale, item.fit, item.fitZh)}</p>
      <div class="actions">
        <Button href={item.githubHref} variant="primary" target="_blank" rel="noreferrer">GitHub</Button>
        <Button href={item.docsHref} variant="secondary">{pick(locale, 'Docs', '文档')}</Button>
      </div>
    </section>

    <section class="split" aria-label={pick(locale, 'Core workflow', '核心工作流')}>
      <div>
        <p class="eyebrow">{pick(locale, 'What it solves', '解决什么问题')}</p>
        <h2>{pick(locale, 'Private snippets should stay close to your work.', '私密片段应该留在你的本地工作流里。')}</h2>
      </div>
      <p>
        {pick(
          locale,
          'Rustzen Clipboard is planned as a focused desktop tool for repeated writing, coding, and operational text. It keeps the product direction simple: fast capture, fast retrieval, and local control.',
          'Rustzen Clipboard 规划为面向写作、编码和运营文本复用的专注桌面工具。产品方向保持简单：快速捕获、快速检索、本地掌控。',
        )}
      </p>
    </section>

    <section class="grid" aria-label={pick(locale, 'Features', '功能')}>
      {features.map((feature) => (
        <article>
          <h2>{pick(locale, feature.title, feature.titleZh)}</h2>
          <p>{pick(locale, feature.body, feature.bodyZh)}</p>
        </article>
      ))}
    </section>

    <section class="grid compact" aria-label={pick(locale, 'Who it is for', '适合谁')}>
      {audiences.map((audience) => (
        <article>
          <h2>{pick(locale, audience.title, audience.titleZh)}</h2>
          <p>{pick(locale, audience.body, audience.bodyZh)}</p>
        </article>
      ))}
    </section>
  </main>
</SiteLayout>

<style>
  .product-detail {
    max-width: 1120px;
    margin: 0 auto;
    padding: clamp(48px, 7vw, 96px) clamp(20px, 5vw, 72px);
  }
  .hero {
    max-width: 820px;
  }
  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5rem);
    line-height: 0.96;
    color: var(--ink);
  }
  .lead {
    max-width: 760px;
    margin: 20px 0 0;
    color: var(--ink-2);
    font-size: 1.18rem;
    line-height: 1.7;
  }
  .fit {
    max-width: 720px;
    margin: 14px 0 0;
    color: var(--muted);
    line-height: 1.7;
  }
  .actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
  }
  .split {
    display: grid;
    grid-template-columns: minmax(260px, 0.8fr) minmax(0, 1fr);
    gap: 28px;
    align-items: start;
    margin-top: clamp(52px, 8vw, 92px);
    padding-top: 34px;
    border-top: 1px solid rgba(148, 163, 184, 0.2);
  }
  .split h2,
  article h2 {
    margin: 0;
    color: var(--ink);
  }
  .split p {
    margin: 0;
    color: var(--ink-2);
    line-height: 1.75;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin-top: 30px;
  }
  .grid.compact {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  article {
    min-height: 190px;
    padding: 24px;
    border: 1px solid var(--glass-1-border);
    border-radius: var(--radius-md);
    background: var(--glass-1-bg);
  }
  article p {
    margin: 12px 0 0;
    color: var(--ink-2);
    line-height: 1.7;
  }
  @media (max-width: 820px) {
    .split,
    .grid,
    .grid.compact {
      grid-template-columns: 1fr;
    }
  }
</style>
