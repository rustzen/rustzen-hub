---
import { Image } from 'astro:assets';
import SiteLayout from '../../layouts/SiteLayout.astro';
import Button from '../../components/Button.astro';
import heroImg from '../../assets/zen-clear-hero.png';
import { product } from '../../data/product';
import { getLocale, pick, type Locale } from '../../i18n';

interface Props {
  locale?: Locale;
}
const { locale = getLocale(Astro.url.pathname) } = Astro.props;
---

<SiteLayout
  title={pick(locale, 'Rustzen Clear — macOS cleaner for developers', 'Rustzen Clear — 开发者 macOS 清理工具')}
  description={pick(locale, product.description, product.descriptionZh)}
  active="Products"
  locale={locale}
>
  <main class="product-page">
    <section class="hero">
      <div>
        <p class="eyebrow">{pick(locale, product.eyebrow, product.eyebrowZh)}</p>
        <h1>{product.name}</h1>
        <p class="lead">{pick(locale, product.description, product.descriptionZh)}</p>
        <div class="actions">
          <Button href={product.download.href} variant="primary">{pick(locale, 'Download for macOS', '下载 macOS 版')}</Button>
          <Button href={product.purchase.href} variant="secondary" target="_blank" rel="noreferrer">{pick(locale, 'Get Pro', '升级 Pro')}</Button>
        </div>
      </div>
      <figure class="media">
        <Image src={heroImg} alt={product.image.alt} widths={[480, 768, 1024, 1536]} sizes="(max-width: 900px) 100vw, 48vw" />
      </figure>
    </section>

    <section class="grid" aria-label={pick(locale, 'Features', '功能')}>
      {product.features.map((feature) => (
        <article class="glass feature">
          <h2>{pick(locale, feature.title, feature.titleZh)}</h2>
          <p>{pick(locale, feature.body, feature.bodyZh)}</p>
        </article>
      ))}
    </section>
  </main>
</SiteLayout>

<style>
  .product-page {
    max-width: 1180px;
    margin: 0 auto;
    padding: clamp(48px, 7vw, 96px) clamp(20px, 5vw, 72px);
  }
  .hero {
    display: grid;
    grid-template-columns: minmax(300px, 0.8fr) minmax(0, 1fr);
    gap: clamp(32px, 6vw, 72px);
    align-items: center;
  }
  h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5rem);
    line-height: 0.96;
    color: var(--ink);
  }
  .lead {
    margin: 20px 0 0;
    color: var(--ink-2);
    font-size: 1.12rem;
  }
  .actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
  }
  .media {
    margin: 0;
    padding: 12px;
    border-radius: var(--radius-xl);
    background: var(--glass-1-bg);
    border: 1px solid var(--glass-1-border);
  }
  .media :global(img) {
    width: 100%;
    border-radius: var(--radius-lg);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    margin-top: clamp(44px, 7vw, 84px);
  }
  .feature {
    padding: 26px;
  }
  .feature h2 {
    margin: 0;
    color: var(--ink);
    font-size: 1.2rem;
  }
  .feature p {
    margin: 10px 0 0;
    color: var(--ink-2);
  }
  @media (max-width: 820px) {
    .hero,
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
