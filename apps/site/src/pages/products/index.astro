---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Button from '../../components/Button.astro';
import { product } from '../../data/product';
import { getLocale, pick, type Locale } from '../../i18n';

interface Props {
  locale?: Locale;
}
const { locale = getLocale(Astro.url.pathname) } = Astro.props;
---

<SiteLayout
  title={pick(locale, 'Products — Rustzen', '产品 — Rustzen')}
  description={pick(locale, 'Rustzen products for local development, productivity, and practical developer workflows.', 'Rustzen 面向本地开发、效率工具和开发者工作流的产品。')}
  active="Products"
  locale={locale}
>
  <main class="page">
    <header class="page-head">
      <p class="eyebrow">Rustzen</p>
      <h1>{pick(locale, 'Products built for practical developer work.', '为真实开发工作打造的产品。')}</h1>
      <p class="sub">{pick(locale, 'Start with Zen Clear, a native macOS cleanup tool for reclaiming development disk space safely.', '从 Zen Clear 开始：一个原生 macOS 清理工具，帮助你安全找回开发数据占用的空间。')}</p>
    </header>

    <section class="product-grid" aria-label={pick(locale, 'Rustzen products', 'Rustzen 产品')}>
      <article class="glass product-card">
        <img src={product.image.src} alt={product.image.alt} />
        <div>
          <p class="eyebrow">{pick(locale, product.status, product.status)}</p>
          <h2>{product.name}</h2>
          <p>{pick(locale, product.description, product.descriptionZh)}</p>
          <div class="actions">
            <Button href="/products/clear" variant="primary">{pick(locale, 'View product', '查看产品')}</Button>
            <Button href="/download" variant="secondary">{pick(locale, 'Download', '下载')}</Button>
          </div>
        </div>
      </article>
    </section>
  </main>
</SiteLayout>

<style>
  .page {
    max-width: 1120px;
    margin: 0 auto;
    padding: clamp(48px, 7vw, 96px) clamp(20px, 5vw, 72px);
  }
  .page-head {
    max-width: 720px;
    margin-bottom: 36px;
  }
  .page-head h1 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1.04;
    color: var(--ink);
  }
  .sub,
  .product-card p {
    color: var(--ink-2);
  }
  .product-card {
    display: grid;
    grid-template-columns: minmax(260px, 0.9fr) minmax(0, 1fr);
    gap: clamp(24px, 5vw, 56px);
    align-items: center;
    padding: clamp(24px, 4vw, 42px);
    border-radius: var(--radius-xl);
  }
  .product-card img {
    width: 100%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--glass-2-border);
  }
  .product-card h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--ink);
  }
  .actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 24px;
  }
  @media (max-width: 820px) {
    .product-card {
      grid-template-columns: 1fr;
    }
  }
</style>
