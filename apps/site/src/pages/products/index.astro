---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Button from '../../components/Button.astro';
import { githubUrl, publicProducts } from '../../data/product';
import { getLocale, pick, type Locale } from '../../i18n';

interface Props {
  locale?: Locale;
}
const { locale = getLocale(Astro.url.pathname) } = Astro.props;

function localizeProductHref(href: string) {
  return locale === 'zh' && href.startsWith('/') ? `/zh${href}` : href;
}
---

<SiteLayout
  title={pick(locale, 'Product — Rustzen', '产品 — Rustzen')}
  description={pick(locale, 'Private Rustzen product surface. The public product page currently shows Clear only.', 'Rustzen 私有产品展示面；当前公开产品页仅显示 Clear。')}
  active="Product"
  locale={locale}
>
  <main class="page">
    <header class="page-head">
      <p class="eyebrow">Rustzen Product</p>
      <h1>{pick(locale, 'Private products, shown deliberately.', '私有产品，谨慎公开展示。')}</h1>
      <p class="sub">
        {pick(
          locale,
          'This page is for commercial product surfaces, not the open-source project index. It currently lists Rustzen Clear only.',
          '这里展示商业产品，而不是开源项目索引。当前仅列出 Rustzen Clear。'
        )}
      </p>
    </header>

    <section class="product-grid" aria-label={pick(locale, 'Rustzen products', 'Rustzen 产品')}>
      {publicProducts.map((item) => (
        <article class="glass product-card">
          <div class="card-head">
            <p class="status">{pick(locale, item.status, item.statusZh)}</p>
            <h2>{pick(locale, item.name, item.nameZh)}</h2>
          </div>
          <p>{pick(locale, item.summary, item.summaryZh)}</p>
          <p class="fit">{pick(locale, item.fit, item.fitZh)}</p>
          <div class="actions">
            <Button href={localizeProductHref(item.href)} variant="primary" target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noreferrer' : undefined}>
              {pick(locale, 'View product', '查看产品')}
            </Button>
          </div>
          <div class="links">
            <a href={item.githubHref} target="_blank" rel="noreferrer">GitHub</a>
            <a href={localizeProductHref(item.docsHref)}>{pick(locale, 'Docs', '文档')}</a>
          </div>
        </article>
      ))}
    </section>

    <section class="source glass-2">
      <div>
        <p class="eyebrow">{pick(locale, 'Open source', '开源')}</p>
        <h2>{pick(locale, 'Follow Rustzen on GitHub.', '在 GitHub 上关注 Rustzen。')}</h2>
      </div>
      <Button href={githubUrl} variant="primary" target="_blank" rel="noreferrer">GitHub</Button>
    </section>
  </main>
</SiteLayout>

<style>
  .page {
    max-width: 1180px;
    margin: 0 auto;
    padding: clamp(48px, 7vw, 96px) clamp(20px, 5vw, 72px);
  }

  .page-head {
    max-width: 820px;
    margin-bottom: 36px;
  }

  .page-head h1,
  .source h2 {
    margin: 0;
    font-family: var(--font-display);
    color: var(--ink);
    letter-spacing: 0;
  }

  .page-head h1 {
    font-size: clamp(2.3rem, 5vw, 4rem);
    line-height: 1.04;
  }

  .sub,
  .product-card p {
    color: var(--ink-2);
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .product-card {
    display: flex;
    min-height: 360px;
    flex-direction: column;
    padding: clamp(24px, 4vw, 34px);
  }

  .card-head {
    margin-bottom: 14px;
  }

  .status {
    margin: 0 0 10px !important;
    color: var(--brand-600) !important;
    font-family: var(--font-mono);
    font-size: 0.78rem !important;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .product-card h2 {
    margin: 0;
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    color: var(--ink);
  }

  .fit {
    margin-top: 0;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: auto;
    padding-top: 24px;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 18px;
  }

  .links a {
    color: var(--brand-600);
    font-weight: 700;
  }

  .source {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-top: 22px;
    padding: clamp(24px, 4vw, 34px);
  }

  .source h2 {
    font-size: clamp(1.6rem, 3vw, 2.3rem);
  }

  @media (max-width: 820px) {
    .product-grid,
    .source {
      grid-template-columns: 1fr;
    }
    .product-grid {
      display: grid;
    }
    .source {
      display: block;
    }
    .source :global(.button) {
      margin-top: 18px;
    }
  }
</style>
