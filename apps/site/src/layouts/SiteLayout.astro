---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import { altPath, getLocale, hasZhMirror, type Locale } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  active?: string;
  image?: string;
  locale?: Locale;
}

const {
  title = 'Rustzen',
  description = 'Zen Clear — a native macOS cleanup app for developers.',
  active,
  locale,
} = Astro.props;

const resolvedLocale: Locale = locale ?? getLocale(Astro.url.pathname);
const pathname = Astro.url.pathname;

const site = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(altPath(pathname, 'en'), site);
const zhCanonical = new URL(altPath(pathname, 'zh'), site);
const mirrored = hasZhMirror(pathname);
const ogImage = new URL('/products/zen-clear-product.png', site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Zen Clear',
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'macOS 13+',
  description: 'A native macOS disk cleanup app for developers.',
  offers: { '@type': 'Offer', price: '10', priceCurrency: 'USD' },
};
---

<!doctype html>
<html lang={resolvedLocale === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#77a8f7" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={resolvedLocale === 'zh' ? zhCanonical : canonical} />
    <title>{title}</title>

    <!-- hreflang alternates -->
    <link rel="alternate" hreflang="en" href={canonical} />
    {mirrored ? <link rel="alternate" hreflang="zh-CN" href={zhCanonical} /> : null}
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={resolvedLocale === 'zh' ? zhCanonical : canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Rustzen" />
    <meta property="og:locale" content={resolvedLocale === 'zh' ? 'zh_CN' : 'en_US'} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('rz-theme');
          if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Nav active={active} locale={resolvedLocale} />
    <slot />
    <footer class="site-footer">
      <p>Rustzen builds Zen Clear for local macOS work.</p>
      <nav class="footer-links" aria-label="Legal and support">
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
        <a href="/refund">Refunds</a>
        <a href="/contact">Contact</a>
      </nav>
    </footer>

    <script is:inline>
      // Theme toggle
      (function () {
        var btn = document.getElementById('theme-toggle');
        if (btn)
          btn.addEventListener('click', function () {
            var dark = document.documentElement.classList.toggle('dark');
            try {
              localStorage.setItem('rz-theme', dark ? 'dark' : 'light');
            } catch (e) {}
          });
      })();

      // Policies dropdown — hover to open (hover-capable devices), click to toggle (touch)
      (function () {
        var drops = Array.prototype.slice.call(document.querySelectorAll('[data-dropdown]'));
        var canHover = window.matchMedia('(hover: hover)').matches;

        function closeAll(except) {
          drops.forEach(function (dd) {
            if (dd === except) return;
            if (dd._rzTimer) {
              clearTimeout(dd._rzTimer);
              dd._rzTimer = null;
            }
            if (dd.classList.contains('is-open')) {
              dd.classList.remove('is-open');
              var t = dd.querySelector('[data-dropdown-trigger]');
              if (t) t.setAttribute('aria-expanded', 'false');
            }
          });
        }
        function setOpen(dd, open) {
          if (open) closeAll(dd);
          if (dd._rzTimer) {
            clearTimeout(dd._rzTimer);
            dd._rzTimer = null;
          }
          dd.classList.toggle('is-open', open);
          var t = dd.querySelector('[data-dropdown-trigger]');
          if (t) t.setAttribute('aria-expanded', String(open));
        }

        drops.forEach(function (dd) {
          var trigger = dd.querySelector('[data-dropdown-trigger]');
          if (!trigger) return;
          trigger.addEventListener('click', function (e) {
            e.stopPropagation();
            setOpen(dd, !dd.classList.contains('is-open'));
          });
          if (canHover) {
            dd.addEventListener('mouseenter', function () {
              setOpen(dd, true);
            });
            dd.addEventListener('mouseleave', function () {
              dd._rzTimer = setTimeout(function () {
                setOpen(dd, false);
              }, 120);
            });
          }
        });

        document.addEventListener('click', function (e) {
          drops.forEach(function (dd) {
            if (dd.classList.contains('is-open') && !dd.contains(e.target)) setOpen(dd, false);
          });
        });
      })();
    </script>
  </body>
</html>
