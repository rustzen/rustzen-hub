---
import { githubUrl } from '../data/product';
import { altPath, localeHref, otherLocale, pick, type Locale } from '../i18n';

interface Props {
  active?: string;
  locale?: Locale;
}

const { active, locale = 'en' } = Astro.props;
const pathname = Astro.url.pathname;

const items = [
  { slug: 'products', en: 'Products', zh: '产品' },
  { slug: 'docs', en: 'Docs', zh: '文档' },
  { slug: 'about', en: 'About', zh: '关于' },
];

const policies = [
  { href: '/privacy', en: 'Privacy', zh: '隐私政策' },
  { href: '/terms', en: 'Terms', zh: '服务条款' },
  { href: '/refund', en: 'Refund', zh: '退款政策' },
  { href: '/contact', en: 'Contact', zh: '联系我们' },
];

const other = otherLocale(locale);
const switchHref = altPath(pathname, other);
const switchLabel = other === 'zh' ? '中文' : 'EN';
---

<header class="site-header">
  <a href={localeHref(locale, '')} class="brand" aria-label="Rustzen home">
    <img class="brand-mark" src="/rustzen-mark.svg" alt="" width="32" height="32" />
    <span class="brand-text">
      <span class="brand-word">Rustzen</span>
      <span class="brand-by">{pick(locale, 'Local-first tools', '本地优先工具')}</span>
    </span>
  </a>

  <nav class="site-nav" aria-label="Primary">
    {
      items.map((item) => (
        <a
          href={localeHref(locale, item.slug, item.anchor)}
          aria-current={active === item.en ? 'page' : undefined}
        >
          {pick(locale, item.en, item.zh)}
        </a>
      ))
    }

    <div class="nav-dropdown" data-dropdown>
      <button type="button" aria-haspopup="true" aria-expanded="false" data-dropdown-trigger>
        <span>{pick(locale, 'Policies', '政策')}</span>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <div class="menu" role="menu">
        {
          policies.map((p) => (
            <a href={p.href} role="menuitem">
              {pick(locale, p.en, p.zh)}
            </a>
          ))
        }
      </div>
    </div>

    <a class="icon-btn" href={switchHref} hreflang={other === 'zh' ? 'zh-CN' : 'en'} aria-label={other === 'zh' ? '切换到中文' : 'Switch to English'} title={switchLabel}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" />
        <path d="M3 12h18M12 3c2.5 2.5 2.5 15.5 0 18M12 3c-2.5 2.5-2.5 15.5 0 18" stroke="currentColor" stroke-width="1.8" />
      </svg>
      <span>{switchLabel}</span>
    </a>

    <button type="button" class="icon-btn" id="theme-toggle" aria-label="Toggle color theme / 切换主题" title="☀ / 🌙">
      <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8" />
        <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
      </svg>
      <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
      </svg>
    </button>

    <a class="nav-cta" href={githubUrl} target="_blank" rel="noreferrer">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M9 19c-4 1.3-4-2-5-2m10 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6A4.7 4.7 0 0 0 17.7 7c.1-.4.5-1.8-.2-3.5 0 0-1-.3-3.5 1.3a12 12 0 0 0-6 0C5.5 3.2 4.5 3.5 4.5 3.5 3.8 5.2 4.2 6.6 4.3 7A4.7 4.7 0 0 0 3 10.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V22" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span>GitHub</span>
    </a>
  </nav>
</header>

<style>
  :global(html:not(.dark)) .icon-moon {
    display: none;
  }
  :global(html.dark) .icon-sun {
    display: none;
  }
</style>
