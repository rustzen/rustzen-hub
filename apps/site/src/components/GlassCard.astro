---
interface Props {
  tier?: 1 | 2;
  as?: 'div' | 'article' | 'section' | 'li';
  class?: string;
}

const { tier = 1, as: Tag = 'div', class: className = '' } = Astro.props;
const cls = [tier === 2 ? 'glass-2' : 'glass', className].filter(Boolean).join(' ');
---

<Tag class={cls}>
  <slot />
</Tag>
