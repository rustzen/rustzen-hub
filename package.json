{
  "name": "rustzen-hub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@12.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspace @rustzen/console",
    "dev:site": "npm run dev --workspace @rustzen/site",
    "dev:console": "npm run dev --workspace @rustzen/console",
    "build:site": "npm run build --workspace @rustzen/site",
    "build:console": "npm run build --workspace @rustzen/console"
  }
}
